DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
TEST_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname_test  # Base de datos separada para tests
# REQUERIDA. Mínimo 32 caracteres. Generar con:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
# REQUERIDA. Fernet key para cifrado de PII en columnas. Generar con:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_LEEWAY_SECONDS=900
CORS_ORIGINS=["http://localhost:5173"]
ENVIRONMENT=development
ADMIN_EMAIL=admin@sistema.com
ADMIN_PASSWORD=         # Sin default; requerida para ejecutar seed.py
# Tamaño máximo del XML SRI a ingresar (MB). Los XMLs reales son < 1 MB.
# Subir solo si algún proveedor emite XMLs anormalmente grandes. Tope absoluto: 50.
MAX_XML_UPLOAD_MB=1
# Tamaño máximo de cualquier request body (MB). Defensa global contra payloads grandes.
# Default: 2. El upload de XML usa su propio límite (MAX_XML_UPLOAD_MB).
MAX_REQUEST_BODY_MB=2
